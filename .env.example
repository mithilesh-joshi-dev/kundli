# Kundli Configuration
# Copy to .env and adjust for your environment.

# Server
KUNDLI_HOST=0.0.0.0
KUNDLI_PORT=8000
KUNDLI_RELOAD=false          # true for development
KUNDLI_WORKERS=1             # increase for production (2-4)
KUNDLI_LOG_LEVEL=info        # debug, info, warning, error

# Application
KUNDLI_DEBUG=false
KUNDLI_DEFAULT_LANG=mr       # mr, hi, en
KUNDLI_DEFAULT_UTC_OFFSET=5.5
KUNDLI_CORS_ORIGINS=*        # comma-separated origins

# Limits
KUNDLI_MAX_YEAR_RANGE=20
KUNDLI_MIN_YEAR=1900
KUNDLI_MAX_YEAR=2100
KUNDLI_RATE_LIMIT=60         # requests per minute per IP
